@page
@{
    ViewData["Title"] = "Workouts";
}

<div class="container">
    <div class="page-header">
        <div>
            <h1 style="margin: 0 0 4px 0; font-size: 1.8rem;">💪 Workouts</h1>
            <p style="margin: 0; color: var(--muted);">Track your fitness workouts</p>
        </div>
        <button class="btn btn-primary">+ Log Workout</button>
    </div>

    <div class="dash-card">
        <h2 style="margin: 0 0 16px 0;">Coming Soon</h2>
        <p style="color: var(--muted); margin: 0;">Workout logging feature will be available soon. Track your exercises, duration, and calories burned.</p>
        <div style="margin-top: 12px;">
            <a href="/" class="btn btn-ghost">← Back to Home</a>
        </div>
    </div>
</div>
