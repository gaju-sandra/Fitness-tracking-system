@page
@model fit.Pages.Auth.RegisterModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Register – FitTrack</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2"/>
<link rel="shortcut icon" href="/favicon.svg?v=2"/>
<link rel="stylesheet" href="~/css/fittrack.css"/>
</head>
<body class="auth-body auth-screen">
<div class="auth-visual" aria-hidden="true">
  <img src="/images/auth-fitness-bg.svg" class="auth-visual-image" alt=""/>
  <div class="auth-orb orb-1"></div>
  <div class="auth-orb orb-2"></div>
  <div class="auth-orb orb-3"></div>
</div>

<main class="auth-page">
  <div class="auth-card auth-card-premium">
    <div class="auth-logo">FitTrack</div>
    <h2>Create Account</h2>
    <p class="text-muted mb-4">Start your fitness journey today</p>
    @if (Model.Error != null)
    {
      <div class="alert alert-danger">@Model.Error</div>
    }
    <form method="post">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="Name" class="input" placeholder="Your name" required/>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="Email" class="input" placeholder="you@example.com" required/>
      </div>
      <div class="form-group">
        <label>Gender</label>
        <select name="Gender" class="input" required>
          <option value="Female">Female</option>
          <option value="Male">Male</option>
          <option value="Prefer not to say" selected>Prefer not to say</option>
        </select>
      </div>
      <div class="form-group">
        <label>Province</label>
        <select id="provinceSelect" name="Province" class="input" required>
          <option value="">Select province</option>
          @foreach (var province in Model.ProvinceOptions)
          {
            if (province.Value == Model.Province)
            {
              <option value="@province.Value" selected>@province.Text</option>
            }
            else
            {
              <option value="@province.Value">@province.Text</option>
            }
          }
        </select>
      </div>
      <div class="form-group">
        <label>Sector</label>
        <select id="sectorSelect" name="LocationId" class="input" required>
          <option value="">Select sector</option>
        </select>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="Password" class="input" placeholder="Min 6 characters" required minlength="6"/>
      </div>
      <div class="form-group">
        <label>Confirm Password</label>
        <input type="password" name="ConfirmPassword" class="input" placeholder="Repeat your password" required minlength="6"/>
      </div>
      <button type="submit" class="btn btn-primary auth-submit">Create Account</button>
    </form>
    <p class="auth-links">Already have an account? <a href="/Auth/Login">Sign in</a></p>
    <p class="auth-links"><a href="/">← Back to Home</a></p>
  </div>
</main>

<footer class="auth-footer">
  <span>© @DateTime.UtcNow.Year FitTrack</span>
  <span>•</span>
  <span>Stronger every day</span>
</footer>
<script src="~/js/fittrack.js"></script>
<script>
  (function () {
    const locations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LocationOptions));
    const selectedProvince = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Province));
    const selectedLocationId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LocationId));
    const provinceSelect = document.getElementById('provinceSelect');
    const sectorSelect = document.getElementById('sectorSelect');

    function fillSectors(province, selectedId) {
      sectorSelect.innerHTML = '<option value="">Select sector</option>';
      if (!province) return;

      locations
        .filter(x => x.Province === province)
        .forEach(x => {
          const option = document.createElement('option');
          option.value = String(x.Id);
          option.textContent = x.Sector;
          if (selectedId && Number(selectedId) === x.Id) {
            option.selected = true;
          }
          sectorSelect.appendChild(option);
        });
    }

    fillSectors(selectedProvince, selectedLocationId);
    provinceSelect.addEventListener('change', function () {
      fillSectors(this.value, null);
    });
  })();
</script>
</body>
</html>
