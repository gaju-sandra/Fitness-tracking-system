@page
@model fit.Pages.Auth.TwoFactorModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Two-Factor – FitTrack</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2"/>
<link rel="shortcut icon" href="/favicon.svg?v=2"/>
<link rel="stylesheet" href="~/css/fittrack.css"/>
</head>
<body class="auth-body">
<div class="auth-card">
  <div class="auth-logo">💪 FitTrack</div>
  <h2>Check your email</h2>
  <p class="text-muted mb-4">Enter the 6-digit code we sent to <strong>@Model.MaskedEmail</strong>.</p>

  @if (Model.Error != null)
  {
    <div class="alert alert-danger">@Model.Error</div>
  }
  @if (Model.Info != null)
  {
    <div class="alert alert-info">@Model.Info</div>
  }

  <form method="post">
    <div class="form-group">
      <label>Verification Code</label>
      <input type="text" name="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code"
             placeholder="123456" required minlength="6" maxlength="6"/>
    </div>
    <button type="submit" class="btn btn-primary w-100 mt-3">Verify</button>
  </form>

  <form method="post" asp-page-handler="Resend" class="mt-3">
    <button type="submit" class="btn btn-secondary w-100">Resend code</button>
  </form>

  <p class="mt-3 text-center"><a href="/Auth/Login">Cancel and go back</a></p>
</div>
<script src="~/js/fittrack.js"></script>
</body>
</html>

