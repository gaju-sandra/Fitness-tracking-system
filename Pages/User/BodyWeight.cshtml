@page
@model fit.Pages.User.BodyWeightModel
@{ ViewData["Title"] = "Body Weight"; }

<div class="page-header">
  <h1>⚖️ Body Weight Tracker</h1>
  <button class="btn btn-primary" onclick="openModal('weightModal')">+ Log Weight</button>
</div>

@if (TempData["Message"] != null) { <div class="alert alert-success">@TempData["Message"]</div> }

<div class="dash-card mb-3">
  <h3>Progress Chart</h3>
  <canvas id="weightChart" height="180"></canvas>
</div>

<div class="filter-bar">
  <form method="get" class="filter-form">
    <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control"/>
    <input type="date" name="dateTo" value="@Model.DateTo" class="form-control"/>
    <button type="submit" class="btn btn-outline">Filter</button>
    <a href="/User/BodyWeight" class="btn btn-outline">Clear</a>
  </form>
</div>

<div class="card">
  <table class="data-table">
    <thead><tr><th>Date</th><th>Weight (kg)</th><th>Note</th><th>Actions</th></tr></thead>
    <tbody>
      @foreach (var e in Model.Entries)
      {
        <tr>
          <td>@e.Date.ToString("MMM d, yyyy")</td>
          <td><strong>@e.Weight kg</strong></td>
          <td>@(e.Note ?? "-")</td>
          <td class="actions">
            <button class="btn btn-sm btn-outline" onclick='editWeight(@System.Text.Json.JsonSerializer.Serialize(new { e.Id, e.Weight, Date = e.Date.ToString("yyyy-MM-dd"), e.Note }))'>Edit</button>
            <form method="post" asp-page-handler="Delete" style="display:inline" onsubmit="return confirm('Delete?')">
              <input type="hidden" name="id" value="@e.Id"/>
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      }
      @if (!Model.Entries.Any()) { <tr><td colspan="4" class="text-center text-muted">No entries yet. Log your first weight!</td></tr> }
    </tbody>
  </table>
</div>

<div class="modal-overlay" id="weightModal">
  <div class="modal">
    <div class="modal-header"><h3 id="wModalTitle">Log Weight</h3><button type="button" onclick="closeModal('weightModal')">✕</button></div>
    <form method="post" asp-page-handler="Save">
      <input type="hidden" name="Entry.Id" id="wId" value="0"/>
      <div class="form-group"><label>Weight (kg)</label><input type="number" step="0.1" name="Entry.Weight" id="wWeight" class="form-control" required/></div>
      <div class="form-group"><label>Date</label><input type="date" name="Entry.Date" id="wDate" class="form-control" required/></div>
      <div class="form-group"><label>Note (optional)</label><input type="text" name="Entry.Note" id="wNote" class="form-control"/></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('weightModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const labels = @Html.Raw(Model.ChartLabels);
const data = @Html.Raw(Model.ChartData);
if (data.length > 0) {
  new Chart(document.getElementById('weightChart'), {
    type: 'line',
    data: { labels, datasets: [{ label: 'Weight (kg)', data, borderColor: '#6c63ff', backgroundColor: 'rgba(108,99,255,0.1)', tension: 0.4, fill: true, pointBackgroundColor: '#6c63ff' }] },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: false } } }
  });
}
function editWeight(e) {
  document.getElementById('wId').value = e.id;
  document.getElementById('wWeight').value = e.weight;
  document.getElementById('wDate').value = e.date;
  document.getElementById('wNote').value = e.note ?? '';
  document.getElementById('wModalTitle').textContent = 'Edit Weight';
  openModal('weightModal');
}
// Set today's date as default
document.getElementById('wDate').value = new Date().toISOString().split('T')[0];
</script>
}
