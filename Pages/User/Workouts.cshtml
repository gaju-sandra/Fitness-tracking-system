@page
@model fit.Pages.User.WorkoutsModel
@{ ViewData["Title"] = "Workouts"; }

<div class="page-header">
  <div class="page-header-copy">
    <h1>🏋️ Workout Log</h1>
    <p class="page-subtitle">Track each session and monitor duration and calories burned.</p>
  </div>
  <button class="btn btn-primary" onclick="openModal('workoutModal')">+ Log Workout</button>
</div>

@if (TempData["Message"] != null) { <div class="alert alert-success">@TempData["Message"]</div> }

<div class="stats-grid">
  <div class="stat-card blue"><div class="stat-icon">🏋️</div><div class="stat-info"><span class="stat-value">@Model.Logs.Count</span><span class="stat-label">Sessions</span></div></div>
  <div class="stat-card green"><div class="stat-icon">⏱️</div><div class="stat-info"><span class="stat-value">@Model.TotalMinutes min</span><span class="stat-label">Total Time</span></div></div>
  <div class="stat-card orange"><div class="stat-icon">🔥</div><div class="stat-info"><span class="stat-value">@Model.TotalCalories kcal</span><span class="stat-label">Total Burned</span></div></div>
</div>

<div class="filter-bar">
  <form method="get" class="filter-form">
    <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control"/>
    <input type="date" name="dateTo" value="@Model.DateTo" class="form-control"/>
    <button type="submit" class="btn btn-outline">Filter</button>
    <a href="/User/Workouts" class="btn btn-outline">Clear</a>
  </form>
</div>

<div class="card">
  <table class="data-table">
    <thead><tr><th>Date</th><th>Plan</th><th>Duration</th><th>Calories Burned</th><th>Notes</th><th>Actions</th></tr></thead>
    <tbody>
      @foreach (var w in Model.Logs)
      {
        <tr>
          <td>@w.Date.ToString("MMM d, yyyy")</td>
          <td><span class="plan-badge">@w.WorkoutPlan.Name</span></td>
          <td>@w.DurationMinutes min</td>
          <td>🔥 @w.CaloriesBurned kcal</td>
          <td>@(w.Notes ?? "-")</td>
          <td class="actions">
            <button class="btn btn-sm btn-outline" onclick='editWorkout(@System.Text.Json.JsonSerializer.Serialize(new { w.Id, w.WorkoutPlanId, Date = w.Date.ToString("yyyy-MM-dd"), w.DurationMinutes, w.CaloriesBurned, w.Notes }))'>Edit</button>
            <form method="post" asp-page-handler="Delete" style="display:inline" onsubmit="return confirm('Delete?')">
              <input type="hidden" name="id" value="@w.Id"/>
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      }
      @if (!Model.Logs.Any()) { <tr><td colspan="6" class="empty-state"><span class="empty-state-emoji">🏋️</span>No workouts logged yet.</td></tr> }
    </tbody>
  </table>
</div>

<div class="modal-overlay" id="workoutModal">
  <div class="modal">
    <div class="modal-header"><h3 id="wkModalTitle">Log Workout</h3><button type="button" onclick="closeModal('workoutModal')">✕</button></div>
    <form method="post" asp-page-handler="Save">
      <input type="hidden" name="Entry.Id" id="wkId" value="0"/>
      <div class="form-group">
        <label>Workout Plan</label>
        <select name="Entry.WorkoutPlanId" id="wkPlan" class="form-control" required>
          @foreach (var p in Model.Plans) { <option value="@p.Id">@p.Name (@p.Difficulty)</option> }
        </select>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Duration (min)</label><input type="number" name="Entry.DurationMinutes" id="wkDur" class="form-control" required min="1"/></div>
        <div class="form-group"><label>Calories Burned</label><input type="number" name="Entry.CaloriesBurned" id="wkCal" class="form-control" required min="0"/></div>
      </div>
      <div class="form-group"><label>Date</label><input type="date" name="Entry.Date" id="wkDate" class="form-control" required/></div>
      <div class="form-group"><label>Notes (optional)</label><textarea name="Entry.Notes" id="wkNotes" class="form-control" rows="2"></textarea></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('workoutModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
document.getElementById('wkDate').value = new Date().toISOString().split('T')[0];
function editWorkout(w) {
  document.getElementById('wkId').value = w.id;
  document.getElementById('wkPlan').value = w.workoutPlanId;
  document.getElementById('wkDur').value = w.durationMinutes;
  document.getElementById('wkCal').value = w.caloriesBurned;
  document.getElementById('wkDate').value = w.date;
  document.getElementById('wkNotes').value = w.notes ?? '';
  document.getElementById('wkModalTitle').textContent = 'Edit Workout';
  openModal('workoutModal');
}
</script>
}
